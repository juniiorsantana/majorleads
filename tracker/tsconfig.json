{
    "compilerOptions": {
        "target": "ES2017",
        "module": "ES2020",
        "moduleResolution": "bundler",
        "lib": [
            "ES2017",
            "DOM"
        ],
        "strict": true,
        "skipLibCheck": true,
        "outDir": "dist",
        "declaration": false,
        "removeComments": true
    },
    "include": [
        "src/**/*"
    ],
    "exclude": [
        "node_modules",
        "dist",
        "tests",
        "src/**/__tests__/*"
    ]
}