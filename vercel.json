{
    "framework": "vite",
    "buildCommand": "npm run build:tracker && npm run build",
    "outputDirectory": "dist",
    "rewrites": [
        {
            "source": "/tracker.js",
            "destination": "/tracker.js"
        },
        {
            "source": "/(.*)",
            "destination": "/index.html"
        }
    ]
}